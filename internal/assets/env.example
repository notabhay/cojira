# =============================================================================
# cojira environment configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Confluence
# -----------------------------------------------------------------------------
CONFLUENCE_BASE_URL=https://confluence.example.com/confluence/
CONFLUENCE_API_TOKEN=your-personal-access-token-here

# -----------------------------------------------------------------------------
# Jira
# -----------------------------------------------------------------------------
JIRA_BASE_URL=https://jira.example.com
JIRA_API_TOKEN=your-api-token-here

# Optional: Email enables basic auth (email + token). Omit for bearer token auth.
# JIRA_EMAIL=

# Optional: Default project for `cojira jira sync`
# JIRA_PROJECT=PROJ

# Optional: REST API version (default: 2)
# JIRA_API_VERSION=2

# Optional: Force auth mode (basic, bearer, or oauth2). Auto-detected if omitted.
# JIRA_AUTH_MODE=basic

# Optional: OAuth 2.0 settings for Atlassian Cloud
# JIRA_OAUTH_ACCESS_TOKEN=
# JIRA_OAUTH_REFRESH_TOKEN=
# JIRA_OAUTH_CLIENT_ID=
# JIRA_OAUTH_CLIENT_SECRET=
# JIRA_OAUTH_TOKEN_URL=https://auth.atlassian.com/oauth/token
# JIRA_OAUTH_CLOUD_ID=
# JIRA_OAUTH_EXPIRY=2026-04-16T12:34:56Z

# Optional: SSL verification (default: true). Set to false to disable (not recommended).
# JIRA_VERIFY_SSL=false

# Optional: Custom user agent
# JIRA_USER_AGENT=cojira/0.1

# Optional: Confluence REST API version (default: 1, use 2 for Cloud page CRUD)
# CONFLUENCE_API_VERSION=1

# Optional: Confluence auth mode (bearer or oauth2)
# CONFLUENCE_AUTH_MODE=bearer

# Optional: OAuth 2.0 settings for Atlassian Cloud Confluence
# CONFLUENCE_OAUTH_ACCESS_TOKEN=
# CONFLUENCE_OAUTH_REFRESH_TOKEN=
# CONFLUENCE_OAUTH_CLIENT_ID=
# CONFLUENCE_OAUTH_CLIENT_SECRET=
# CONFLUENCE_OAUTH_TOKEN_URL=https://auth.atlassian.com/oauth/token
# CONFLUENCE_OAUTH_CLOUD_ID=
# CONFLUENCE_OAUTH_EXPIRY=2026-04-16T12:34:56Z
