# =============================================================================
# cojira environment configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Confluence
# -----------------------------------------------------------------------------
CONFLUENCE_BASE_URL=https://confluence.example.com/confluence/
CONFLUENCE_API_TOKEN=your-personal-access-token-here

# -----------------------------------------------------------------------------
# Jira
# -----------------------------------------------------------------------------
JIRA_BASE_URL=https://jira.example.com
JIRA_API_TOKEN=your-api-token-here

# Optional: Email enables basic auth (email + token). Omit for bearer token auth.
# JIRA_EMAIL=

# Optional: Default project for `cojira jira sync`
# JIRA_PROJECT=PROJ

# Optional: REST API version (default: 2)
# JIRA_API_VERSION=2

# Optional: Force auth mode (basic or bearer). Auto-detected if omitted.
# JIRA_AUTH_MODE=basic

# Optional: SSL verification (default: true). Set to false to disable (not recommended).
# JIRA_VERIFY_SSL=false

# Optional: Custom user agent
# JIRA_USER_AGENT=cojira/0.1
