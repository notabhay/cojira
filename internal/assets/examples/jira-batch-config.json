{
  "base_dir": ".",
  "operations": [
    {
      "op": "create",
      "template": "jira-create-template.json",
      "vars": ["PROJECT=PROJ", "SUMMARY=Parent task from batch", "TYPE=Task"],
      "capture": "PARENT_KEY"
    },
    {
      "op": "create",
      "inline": {
        "fields": {
          "project": {
            "key": "PROJ"
          },
          "issuetype": {
            "name": "Sub-task"
          },
          "summary": "Child issue created from inline batch payload",
          "parent": {
            "key": "${PARENT_KEY}"
          }
        }
      }
    },
    {
      "op": "update",
      "issue": "${PARENT_KEY}",
      "inline": {
        "fields": {
          "priority": {
            "name": "High"
          }
        }
      },
      "notify": false
    }
  ]
}
